CODE_RAG_TENANT_ID=default
CODE_RAG_BRANCH=develop
CODE_RAG_GITLAB_BASE_URL=https://gitlab.com
CODE_RAG_GITLAB_TOKEN=
CODE_RAG_GITLAB_WEBHOOK_SECRET=
CODE_RAG_ELASTICSEARCH_URL=http://localhost:9200
CODE_RAG_ELASTICSEARCH_API_KEY=
CODE_RAG_EMBEDDING_SERVICE_URL=
CODE_RAG_LATE_INTERACTION_DIMENSION=128
# Answer backend: extractive (default) | anthropic | http (uses the URL below).
CODE_RAG_ANSWER_PROVIDER=extractive
CODE_RAG_LLM_ANSWER_SERVICE_URL=
CODE_RAG_ANTHROPIC_API_KEY=
CODE_RAG_ANTHROPIC_MODEL=claude-opus-4-8
CODE_RAG_ANTHROPIC_MAX_TOKENS=2048
CODE_RAG_MIN_ANSWER_SOURCES=1
CODE_RAG_MIN_ANSWER_SCORE=0
CODE_RAG_HTTP_RETRIES=3
CODE_RAG_HTTP_RETRY_BACKOFF_SECONDS=0.25
CODE_RAG_CLONE_CACHE_DIR=.cache/repos
CODE_RAG_WORKTREE_DIR=.cache/worktrees
CODE_RAG_REPO_METADATA_PATH=
CODE_RAG_EMBEDDING_DIMENSION=384
CODE_RAG_MAX_FILE_BYTES=750000
CODE_RAG_MAX_CHUNK_CHARS=7000
CODE_RAG_MIN_CHUNK_CHARS=300
CODE_RAG_MAX_INDEX_WORKERS=2
CODE_RAG_INDEX_FILE_WORKERS=4
CODE_RAG_MAX_SYMBOL_REFERENCES=100
CODE_RAG_REUSE_EXISTING_EMBEDDINGS=true
CODE_RAG_ALLOW_REQUEST_SUPPLIED_PERMISSIONS=false
CODE_RAG_SECRET_SCANNING_ENABLED=true
CODE_RAG_SKIP_CHUNKS_WITH_HIGH_CONFIDENCE_SECRETS=false
# API authentication. JSON mapping of API key -> trusted user_id. Leave empty
# for local development (no key required, request user_id trusted).
# Example: CODE_RAG_API_KEYS={"svc-key-123":"alice"}
CODE_RAG_API_KEYS={}
# Observability. log_format: json (aggregators) | text (local dev).
CODE_RAG_LOG_LEVEL=INFO
CODE_RAG_LOG_FORMAT=json
# Per-identity rate limit for /search and /answer. 0 disables it.
CODE_RAG_RATE_LIMIT_REQUESTS_PER_MINUTE=0
